<!DOCTYPE html>
<html lang="id">
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Grok Lite - AI Chat</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #000; color: #fff; font-family: sans-serif; }
        .chat-box { height: 70vh; overflow-y: auto; border: 1px solid #333; }
    </style>
</head>
<body class="p-4">
    <h1 class="text-2xl font-bold mb-4 text-center text-blue-500">Grok Lite</h1>
    
    <div id="chatWindow" class="chat-box p-4 rounded-lg bg-zinc-900 mb-4">
        </div>

    <div class="flex gap-2">
        <input id="userInput" type="text" class="flex-1 p-2 rounded bg-zinc-800 border border-zinc-700 text-white" placeholder="Tanya sesuatu yang gila...">
        <button onclick="sendMessage()" class="bg-blue-600 px-4 py-2 rounded font-bold">Kirim</button>
    </div>

    <script>
        const API_KEY = "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";

        async function sendMessage() {
            const input = document.getElementById('userInput');
            const chatWindow = document.getElementById('chatWindow');
            if (!input.value) return;

            // Tampilkan pesan user
            chatWindow.innerHTML += `<p class='mb-2 text-blue-400'><b>Anda:</b> ${input.value}</p>`;
            const userText = input.value;
            input.value = '';

            try {
                const response = await fetch("https://api.groq.com/openai/v1/chat/completions", {
                    method: "POST",
                    headers: {
                        "Authorization": `Bearer ${API_KEY}`,
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        model: "llama3-8b-8192",
                        messages: [
                            { role: "system", content: "Kamu adalah asisten AI yang cerdas, blak-blakan, dan sarkastik seperti Grok." },
                            { role: "user", content: userText }
                        ]
                    })
                });

                const data = await response.json();
                const aiReply = data.choices[0].message.content;

                // Tampilkan jawaban AI
                chatWindow.innerHTML += `<p class='mb-4 text-zinc-300'><b>Grok:</b> ${aiReply}</p>`;
                chatWindow.scrollTop = chatWindow.scrollHeight;
            } catch (error) {
                chatWindow.innerHTML += `<p class='text-red-500'>Error: Gagal terhubung ke AI.</p>`;
            }
        }
    </script>
</body>
</html>
